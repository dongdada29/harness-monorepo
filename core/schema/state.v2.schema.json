{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Harness State Schema v2",
  "type": "object",
  "properties": {
    "_schema": { 
      "type": "string",
      "const": "harness-state-v2"
    },
    "version": { 
      "type": "string",
      "const": "2.0.0"
    },
    "project": { "type": "string" },
    "type": { "type": "string", "enum": ["business", "tech", "generic"] },
    "platform": { "type": "string" },
    "checkpoints": {
      "type": "object",
      "properties": {
        "CP0": { "$ref": "#/definitions/checkpoint" },
        "CP1": { "$ref": "#/definitions/checkpoint" },
        "CP2": { "$ref": "#/definitions/checkpoint" },
        "CP3": { "$ref": "#/definitions/checkpoint" },
        "CP4": { "$ref": "#/definitions/checkpoint" }
      }
    },
    "gates": {
      "type": "object",
      "properties": {
        "init": { "type": "string", "enum": ["pending", "in_progress", "passed", "failed"] },
        "plan": { "type": "string", "enum": ["pending", "in_progress", "passed", "failed"] },
        "exec": { "type": "string", "enum": ["pending", "in_progress", "passed", "failed"] },
        "verify": { "type": "string", "enum": ["pending", "in_progress", "passed", "failed"] },
        "complete": { "type": "string", "enum": ["pending", "in_progress", "passed", "failed"] }
      },
      "additionalProperties": true
    },
    "memory": {
      "type": "object",
      "properties": {
        "lastRetrieval": {
          "type": "object",
          "properties": {
            "timestamp": { "type": "string", "format": "date-time" },
            "type": { "type": "string", "enum": ["cp0_init", "cp1_plan", "cp2_exec", "cp3_verify"] },
            "episodicHits": { "type": "number" },
            "semanticHits": { "type": "number" }
          },
          "required": ["timestamp", "type"]
        },
        "episodicBuffer": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "taskId": { "type": "string" },
              "summary": { "type": "string" },
              "resolution": { "type": "string" },
              "success": { "type": "boolean" },
              "relevanceScore": { "type": "number", "minimum": 0, "maximum": 1 },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "semanticCache": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "healing": {
      "type": "object",
      "description": "CP4 self-healing loop state",
      "properties": {
        "enabled": { "type": "boolean" },
        "maxAttempts": { "type": "number", "minimum": 1, "maximum": 10 },
        "currentAttempt": { "type": "number", "minimum": 0 },
        "lastAttempt": { "type": ["string", "null"] },
        "lastError": { "type": ["string", "null"] },
        "retryHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "attempt": { "type": "number" },
              "timestamp": { "type": "string", "format": "date-time" },
              "failedGates": { "type": "array", "items": { "type": "string" } },
              "errorSummary": { "type": "string" },
              "filesTouched": { "type": "array", "items": { "type": "string" } },
              "status": { "type": "string", "enum": ["passed", "failed"] }
            },
            "required": ["attempt", "timestamp", "failedGates", "errorSummary", "status"]
          }
        },
        "autoHeal": { "type": "boolean" }
      },
      "required": ["enabled", "maxAttempts", "currentAttempt", "retryHistory", "autoHeal"]
    },
    "metrics": {
      "type": "object",
      "properties": {
        "tasksCompleted": { "type": "number" },
        "tasksBlocked": { "type": "number" },
        "mcpToolsInvoked": { "type": "number" },
        "retrievalHits": { "type": "number" }
      }
    },
    "autonomy": {
      "type": "object",
      "properties": {
        "level": {
          "type": "number",
          "minimum": 1,
          "maximum": 9,
          "description": "Agent autonomy level (1-9, default 4)"
        },
        "requireApprovalFor": {
          "type": "array",
          "items": { "type": "string" }
        },
        "autoMergeOnCI": {
          "type": "boolean"
        },
        "lastPR": {
          "type": "object",
          "properties": {
            "number": { "type": "number" },
            "url": { "type": "string", "format": "uri" },
            "branch": { "type": "string" },
            "mergedAt": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "pr": {
      "type": "object",
      "properties": {
        "number": { "type": "number" },
        "url": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "branch": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "merged", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "mergedAt": { "type": "string", "format": "date-time" }
      }
    },
    "recentChanges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "type": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "taskHistory": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "task": { "type": "string" },
          "completedAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "lastUpdated": { "type": "string", "format": "date-time" },
    "currentTask": { "type": ["string", "null"] },
    "taskStatus": { "type": ["string", "null"] }
  },
  "definitions": {
    "checkpoint": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "failed", "skipped"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "notes": { "type": "string" },
        "error": { "type": "string" }
      }
    }
  },
  "required": ["_schema", "version", "project", "checkpoints", "gates"]
}
