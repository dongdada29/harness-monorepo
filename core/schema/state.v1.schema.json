{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Harness State Schema v1",
  "type": "object",
  "properties": {
    "_schema": { "type": "string" },
    "version": { "type": "string" },
    "project": { "type": "string" },
    "type": { "type": "string" },
    "platform": { "type": "string" },
    "checkpoints": {
      "type": "object"
    },
    "gates": { "type": "object" },
    "metrics": {
      "type": "object",
      "properties": {
        "tasksCompleted": { "type": "number" },
        "tasksBlocked": { "type": "number" }
      }
    }
  }
}
