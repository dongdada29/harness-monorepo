{
  "name": "@harness/monorepo",
  "version": "1.0.0",
  "description": "Agent Harness Monorepo - 所有 Agent 开发工作流的统一管理",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:agent-harness": "cp packages/agent-harness/CLAUDE.md ./CLAUDE.md",
    "dev:nuwax": "rsync -av --exclude='.git' packages/nuwax-harness/ /path/to/nuwax/",
    "dev:electron": "rsync -av --exclude='.git' packages/electron-harness/ /path/to/electron/",
    "dev:generic": "rsync -av --exclude='.git' packages/generic-harness/ /path/to/project/",
    "list": "ls packages/",
    "help": "cat README.md"
  },
  "keywords": [
    "agent",
    "claude-code",
    "cursor",
    "codex",
    "harness",
    "workflow"
  ],
  "author": "dongdada29",
  "license": "MIT"
}
